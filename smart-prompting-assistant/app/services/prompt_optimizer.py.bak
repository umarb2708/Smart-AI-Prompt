class PromptOptimizer:
    def __init__(self):
        self.optimization_strategies = {
            'clarity': self._add_clarity,
            'structure': self._add_structure,
            'specificity': self._add_specificity,
            'context': self._add_context
        }

    def categorize_prompt(self, prompt):
        """
        Categorize prompt into zero-shot, few-shot, or chain-of-thought.
        Returns: tuple (category, reasoning)
        """
        prompt_lower = prompt.lower()
        prompt_length = len(prompt.split())
        
        # Check for chain-of-thought indicators
        cot_indicators = [
            'step by step', 'explain', 'reasoning', 'think through', 'analyze',
            'how', 'why', 'process', 'methodology', 'elaborate', 'detail',
            'break down', 'walk through', 'show your work', 'logic'
        ]
        
        # Check for few-shot indicators (examples, demonstrations)
        few_shot_indicators = [
            'example', 'like', 'similar to', 'such as', 'for instance',
            'demonstrate', 'show me', 'sample', 'illustration'
        ]
        
        # Count indicators
        cot_count = sum(1 for indicator in cot_indicators if indicator in prompt_lower)
        few_shot_count = sum(1 for indicator in few_shot_indicators if indicator in prompt_lower)
        
        # Decision logic
        if cot_count >= 2 or any(phrase in prompt_lower for phrase in ['step by step', 'explain how', 'break down', 'reasoning']):
            return 'chain-of-thought', 'Requires detailed step-by-step reasoning'
        
        if few_shot_count > 0 or prompt_length > 50 or any(word in prompt_lower for word in ['example', 'like this']):
            return 'few-shot', 'Benefits from examples and demonstrations'
        
        # Default to zero-shot for simple, direct requests
        if prompt_length < 20 and '?' not in prompt and not any(word in prompt_lower for word in ['explain', 'describe', 'analyze']):
            return 'zero-shot', 'Simple, direct task'
        
        # If unclear but detailed, use few-shot
        if prompt_length > 30:
            return 'few-shot', 'Complex task benefits from examples'
        
        return 'zero-shot', 'Straightforward request'

    def optimize_prompt(self, prompt):
        """
        Optimize a prompt by first categorizing it, then applying appropriate strategy.
        Returns: tuple (optimized_prompt, category, reasoning)
        """
        prompt = prompt.strip()
        
        if not prompt:
            return "Please provide a prompt to optimize.", 'zero-shot', 'Empty prompt'
        
        # Categorize the prompt
        category, reasoning = self.categorize_prompt(prompt)
        
        # Apply optimization based on category
        if category == 'zero-shot':
            optimized = self._optimize_zero_shot(prompt)
        elif category == 'few-shot':
            optimized = self._optimize_few_shot(prompt)
        else:  # chain-of-thought
            optimized = self._optimize_chain_of_thought(prompt)
        
        return optimized, category, reasoning

    def _optimize_zero_shot(self, prompt):
        """
        Zero-shot: Minimal enhancement, return clean version of input.
        """
        # Just clean up the prompt without adding much
        cleaned = prompt.strip()
        
        # Ensure proper capitalization
        if cleaned and cleaned[0].islower():
            cleaned = cleaned[0].upper() + cleaned[1:]
        
        # Ensure proper punctuation
        if cleaned and not cleaned[-1] in '.!?':
            if '?' in cleaned or any(cleaned.lower().startswith(q) for q in ['what', 'how', 'why', 'when', 'where', 'who']):
                cleaned += '?'
            else:
                cleaned += '.'
        
        return cleaned

    def _optimize_few_shot(self, prompt):
        """
        Few-shot: Add examples and demonstrations to guide the AI.
        """
        # Detect task type for appropriate examples
        task_type = self._detect_task_type(prompt)
        
        optimized = f"""{prompt}

Please provide your response following these guidelines:
- Include relevant examples to illustrate your points
- Show practical demonstrations where applicable
- Use clear formatting and structure
- Provide context for better understanding

Example format:
1. Main response with explanation
2. Concrete examples showing the concept
3. Additional variations or use cases"""
        
        return optimized

    def _optimize_chain_of_thought(self, prompt):
        """
        Chain-of-thought: Add detailed step-by-step reasoning structure.
        """
        task_type = self._detect_task_type(prompt)
        
        optimized = f"""{prompt}

Please approach this systematically using step-by-step reasoning:

1. **Understanding**: First, break down what is being asked
2. **Analysis**: Examine each component or aspect
3. **Reasoning**: Think through the logic and connections
4. **Solution/Explanation**: Provide the answer with justification
5. **Verification**: Validate the reasoning and check for completeness

For each step:
- Explain your thought process clearly
- Show intermediate reasoning
- Connect ideas logically
- Justify your conclusions with evidence or examples

Think through this carefully and show all your reasoning."""
        
        return optimized

    def _detect_task_type(self, prompt):
        """Helper method to detect task type from prompt."""
        prompt_lower = prompt.lower()
        
        if any(word in prompt_lower for word in ['code', 'program', 'function', 'script']):
            return 'coding'
        elif any(word in prompt_lower for word in ['write', 'essay', 'article', 'blog']):
            return 'writing'
        elif any(word in prompt_lower for word in ['analyze', 'evaluate', 'compare', 'assess']):
            return 'analysis'
        elif any(word in prompt_lower for word in ['explain', 'describe', 'what is', 'define']):
            return 'explanation'
        elif any(word in prompt_lower for word in ['calculate', 'solve', 'math', 'equation']):
            return 'math'
        else:
            return 'general'

    def _is_question(self, prompt):
        """Check if prompt is a question."""
        return '?' in prompt or prompt.lower().startswith(('what', 'how', 'why', 'when', 'where', 'who', 'can', 'could', 'would', 'should'))

    def _is_instruction(self, prompt):
        """Check if prompt is an instruction."""
        instruction_words = ['write', 'create', 'generate', 'make', 'build', 'explain', 'describe', 'list', 'summarize']
        return any(prompt.lower().startswith(word) for word in instruction_words)

    def _is_creative_request(self, prompt):
        """Check if prompt is a creative request."""
        creative_words = ['story', 'poem', 'essay', 'article', 'blog', 'script', 'song']
        return any(word in prompt.lower() for word in creative_words)

    def evaluate_prompt(self, prompt):
        """Evaluate the effectiveness of the prompt."""
        score = 0
        
        # Length check
        if len(prompt) > 10:
            score += 20
        if len(prompt) > 50:
            score += 20
        
        # Question mark check
        if '?' in prompt:
            score += 10
        
        # Specificity check
        specific_words = ['specific', 'detailed', 'explain', 'describe', 'how', 'what', 'why']
        if any(word in prompt.lower() for word in specific_words):
            score += 20
        
        # Structure check
        if any(char in prompt for char in [':', '\n', '-']):
            score += 15
        
        # Context check
        context_words = ['context', 'background', 'because', 'regarding', 'about']
        if any(word in prompt.lower() for word in context_words):
            score += 15
        
        return min(score, 100)

    def reformat_prompt(self, prompt):
        """Reformat the prompt for better AI interaction."""
        prompt = prompt.strip()
        
        # Capitalize first letter
        if prompt:
            prompt = prompt[0].upper() + prompt[1:]
        
        # Ensure proper punctuation
        if not prompt.endswith(('.', '?', '!')):
            prompt += '.'
        
        # Add spacing after punctuation
        prompt = prompt.replace('?', '? ').replace('.', '. ').replace('!', '! ')
        prompt = ' '.join(prompt.split())  # Remove extra spaces
        
        return prompt


# Create a default instance
_optimizer = PromptOptimizer()

# Export standalone functions for backward compatibility
def optimize_prompt(prompt):
    """Optimize a prompt using the default optimizer instance."""
    # Extract text from Prompt object or convert to string
    if hasattr(prompt, 'user_input'):
        prompt_text = prompt.user_input
    elif hasattr(prompt, 'formatted_prompt'):
        prompt_text = prompt.formatted_prompt
    elif hasattr(prompt, 'content'):
        prompt_text = prompt.content
    else:
        prompt_text = str(prompt)
    
    optimized, category, reasoning = _optimizer.optimize_prompt(prompt_text)
    return {
        'optimized_prompt': optimized,
        'category': category,
        'reasoning': reasoning
    }

def evaluate_prompt(prompt):
    """Evaluate a prompt using the default optimizer instance."""
    return _optimizer.evaluate_prompt(prompt.content if hasattr(prompt, 'content') else str(prompt))

def reformat_prompt(prompt):
    """Reformat a prompt using the default optimizer instance."""
    return _optimizer.reformat_prompt(prompt.content if hasattr(prompt, 'content') else str(prompt))
